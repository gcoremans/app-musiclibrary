{
  "version": "0.1",
  "prefixes": {
    "schema": "http://schema.org/"
  },
  "resources": {
    "releases": {
      "name": "release",
      "class": "schema:MusicRelease",
      "attributes": {
        "title": {
          "type": "string",
          "predicate": "schema:name"
        },
        "credit": {
          "type": "string",
          "predicate": "schema:creditedTo"
        },
        "format": {
          "type": "string",
          "predicate": "schema:musicReleaseFormat"
        }
      },
      "relationships": {
        "tracks": {
          "predicate": "schema:track",
          "target": "recording",
          "cardinality": "many"
        },
        "group": {
          "predicate": "schema:albumRelease",
          "target": "release-group",
          "cardinality": "one",
          "inverse": true
        }
      },
      "features": ["include-uri"],
      "new-resource-base": "http://musicbrainz.org/release/"
    },

    "recordings": {
      "name": "recording",
      "class": "schema:MusicRecording",
      "attributes": {
        "title": {
          "type": "string",
          "predicate": "schema:name"
        },
        "credit": {
          "type": "string",
          "predicate": "schema:creditedTo"
        },
        "duration": {
          "type": "string",
          "predicate": "schema:duration"
        }
      },
      "relationships": {
        "on": {
          "predicate": "schema:track",
          "target": "release",
          "cardinality": "many",
          "inverse": true
        },
        "by": {
          "predicate": "schema:byArtist",
          "target": "artist",
          "cardinality": "many"
        }
      },
      "features": ["include-uri"],
      "new-resource-base": "http://musicbrainz.org/recording/"
    },

    "artists": {
      "name": "artist",
      "class": "schema:MusicGroup",
      "attributes": {
        "name": {
          "predicate": "schema:name",
          "type": "string"
        }
      },
      "relationships": {
        "albums": {
          "predicate": "schema:album",
          "target": "release-group",
          "cardinality": "many"
        },
        "tracks": {
          "predicate": "schema:byArtist",
          "target": "recording",
          "cardinality": "many",
          "inverse": true
        }
      },
      "features": ["include-uri"],
      "new-resource-base": "http://musicbrainz.org/artist/"
    },

    "release-groups": {
      "name": "release-group",
      "class": "schema:MusicAlbum",
      "attributes": {
        "title": {
          "predicate": "schema:name",
          "type": "string"
        },
        "credit": {
          "predicate": "schema:creditedTo",
          "type": "string"
        }
      },
      "relationships": {
        "artists": {
          "predicate": "schema:album",
          "target": "artist",
          "cardinality": "many",
          "inverse": true
        },
        "releases": {
          "predicate": "schema:albumRelease",
          "target": "release",
          "cardinality": "many"
        }
      },
      "features": ["include-uri"],
      "new-resource-base": "http://musicbrainz.org/release-group/"
    }
  }
}
